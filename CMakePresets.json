{
    "version": 9,
    "configurePresets": [
        {
            "name": "vcpkg",
            "hidden": true,
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
        },
        {
            "name": "msvc",
            "inherits": "vcpkg",
            "description": "Visual Studio 18 2026",
            "generator": "Visual Studio 18 2026",
            "architecture": "x64",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "msvc",
            "configurePreset": "msvc",
            "configuration": "Debug"
        },
        {
            "name": "tests",
            "inherits": "msvc",
            "targets": [
                "run_callback",
                "run_switch_coro",
                "run_coroutine2",
                "run_context_continuation",
                "run_context_fiber",
                "run_fiber",
                "run_std_coroutine",
                "run_use_awaitable",
                "run_cobalt",
                "run_stdexec"
            ]
        }
    ],
    "testPresets": [
        {
            "name": "msvc",
            "configurePreset": "msvc",
            "configuration": "Debug"
        },
        {
            "name": "tests",
            "inherits": "msvc"
        }
    ],
    "workflowPresets": [
        {
            "name": "msvc",
            "steps": [
                {
                    "type": "configure",
                    "name": "msvc"
                },
                {
                    "type": "build",
                    "name": "msvc"
                },
                {
                    "type": "test",
                    "name": "msvc"
                }
            ]
        },
        {
            "name": "tests",
            "steps": [
                {
                    "type": "configure",
                    "name": "msvc"
                },
                {
                    "type": "build",
                    "name": "tests"
                },
                {
                    "type": "test",
                    "name": "tests"
                }
            ]
        }
    ]
}